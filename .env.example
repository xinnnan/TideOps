# Public browser-safe values only.
# Put real values in `.env.local`, which is already ignored by git.
# Do not commit the Supabase service role key to this repository.

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Optional compatibility fallback for older Supabase projects:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
